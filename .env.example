# WordPress REST API
WP_API_URL=https://YOUR_WP_DOMAIN/wp-json/wp/v2
WP_USER=YOUR_WP_USERNAME
WP_APP_PASSWORD=YOUR_APPLICATION_PASSWORD

# サーバー Basic 認証（.htaccess による認証がある場合のみ設定）
WP_BASIC_USER=YOUR_BASIC_AUTH_USER
WP_BASIC_PASSWORD=YOUR_BASIC_AUTH_PASSWORD

# Slack 通知（任意）
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# VOD ラインナップ（月次新着）の出力先 GCS バケット名
GCS_LINEUP_BUCKET=vod-lineup
