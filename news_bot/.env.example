# Google Sheets（サービスアカウント）
GOOGLE_SHEETS_SPREADSHEET_ID=YOUR_SPREADSHEET_ID
GOOGLE_SHEETS_CREDENTIALS_JSON=YOUR_SERVICE_ACCOUNT_JSON_ONE_LINE

# Claude API（AI判定・投稿文生成）
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY

# ChatGPT/Grok（AI判定の精度比較テスト用。NEWS_BOT_JUDGE_PROVIDERSで有効にした場合のみ必須）
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
GROK_API_KEY=YOUR_GROK_API_KEY

# AI判定プロバイダー設定（既定はclaudeのみ・比較テスト時は "claude,openai,grok" 等を指定）
NEWS_BOT_JUDGE_PROVIDERS=claude
# 最終ランクの決定方式（primary=先頭プロバイダー採用 / majority=多数決）
NEWS_BOT_JUDGE_DECISION=primary

# X API v2（Pay-Per-Use, OAuth1.0aユーザーコンテキスト）
X_API_KEY=YOUR_X_API_KEY
X_API_SECRET=YOUR_X_API_SECRET
X_ACCESS_TOKEN=YOUR_X_ACCESS_TOKEN
X_ACCESS_TOKEN_SECRET=YOUR_X_ACCESS_TOKEN_SECRET

# Slack（承認フロー）
# 承認リアクションの検知には Incoming Webhook ではなく Bot Token が必要
SLACK_BOT_TOKEN=YOUR_SLACK_BOT_TOKEN
SLACK_APPROVAL_CHANNEL_ID=YOUR_SLACK_CHANNEL_ID
